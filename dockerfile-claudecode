# Shaka + Claude Code — isolated test environment
# Provides full isolation — no writes to host ~/.config/shaka/ or global bun state
#
# Usage:
#   docker compose run --rm claudecode          # run all checks (typecheck + lint + test)
#   docker compose run --rm claudecode bun test # run tests only
#   docker compose run --rm claudecode sh       # interactive shell inside container
#
# E2E tests:
#   docker compose run --rm claudecode bash test/e2e/claude-hooks.sh

FROM debian:bookworm-slim

LABEL org.opencontainers.image.title="shaka-claudecode" \
      org.opencontainers.image.description="Shaka dev/test environment with Claude Code provider"

# Install curl (needed for bun + Claude Code installers), then clean up
RUN apt-get update && \
    apt-get install -y --no-install-recommends curl ca-certificates unzip && \
    rm -rf /var/lib/apt/lists/*

# Create non-root user
RUN useradd -m -s /bin/bash shakaUser
USER shakaUser
WORKDIR /home/shakaUser

# Install bun (user-level — everything under ~/.bun/)
RUN curl -fsSL https://bun.sh/install | bash
ENV PATH="/home/shakaUser/.bun/bin:${PATH}"

# Install Claude Code (user-level — binary at ~/.local/bin/claude)
RUN curl -fsSL https://claude.ai/install.sh | bash && \
    mkdir -p /home/shakaUser/.claude
ENV PATH="/home/shakaUser/.local/bin:${PATH}"

# Set up app directory
WORKDIR /home/shakaUser/app

# Install dependencies (layer caching)
COPY --chown=shakaUser:shakaUser package.json bun.lock ./
RUN bun install --frozen-lockfile && bun link

# Copy source
COPY --chown=shakaUser:shakaUser src/ src/
COPY --chown=shakaUser:shakaUser defaults/ defaults/
COPY --chown=shakaUser:shakaUser test/ test/
COPY --chown=shakaUser:shakaUser tsconfig.json biome.json ./

# Default: run all checks (typecheck + lint + test)
CMD ["bun", "run", "check"]
