<% }) %>

You SHOULD spawn these agents in BUILD/EXECUTE phases.
<% } %>
<% if (it.thinking && it.thinking.length > 0) { %>

🧠 SUGGESTED THINKING TOOLS (validate in THINK phase):
<% it.thinking.forEach(function(tool) { %>
• <%= tool.name %> — <%= tool.description %>
<% }) %>
<% } %>
</system-reminder>
